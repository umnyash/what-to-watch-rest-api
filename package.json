{
  "name": "what-to-watch-rest-api",
  "version": "1.0.0",
  "description": "REST API for what-to-watch",
  "author": "umnyash",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "start": "npm run build && node ./dist/main.rest.js",
    "start:dev": "npm run ts ./src/main.rest.ts | pino-pretty --colorize --translateTime SYS:standard",
    "build": "npm run clean && npm run compile",
    "lint": "eslint src/",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "tsc --noEmit && node --no-warnings=ExperimentalWarning --loader ts-node/esm",
    "mock:server": "json-server ./mocks/mock-server-data.json --host localhost --port 3123"
  },
  "devDependencies": {
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.6",
    "@types/node": "22.13.1",
    "eslint": "9.20.0",
    "json-server": "1.0.0-beta.15",
    "pino-pretty": "13.1.3",
    "rimraf": "6.0.1",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "5.7.3",
    "typescript-eslint": "8.23.0"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "dotenv": "16.4.7",
    "inversify": "6.2.2",
    "pino": "9.6.0",
    "reflect-metadata": "0.2.2"
  }
}
